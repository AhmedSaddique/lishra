{%- style -%}
  {%- assign accent_rgb = section.settings.accent_color | color_to_rgb | remove: 'rgb(' | remove: ')' | remove: ' ' -%}
  .custom-newsletter-v2 {
    --cn-bg: {{ section.settings.bg_color }};
    --cn-text: {{ section.settings.text_color }};
    --cn-accent: {{ section.settings.accent_color }};
    --cn-accent-rgb: {{ accent_rgb }};
    --cn-border: {{ section.settings.border_color }};
    background-color: var(--cn-bg);
    color: var(--cn-text);
    padding: 80px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    position: relative;
    border-bottom: 1px solid var(--cn-border);
  }

  .cn-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .cn-newsletter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }

  .cn-newsletter__info {
    max-width: 500px;
  }

  .cn-newsletter__title {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
    color: var(--cn-text);
  }

  .cn-newsletter__subtitle {
    font-size: 16px;
    opacity: 0.7;
    margin: 0;
  }

  .cn-newsletter__form {
    flex: 1;
    max-width: 450px;
  }

  .cn-newsletter__field {
    display: flex;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--cn-border);
    border-radius: 12px;
    padding: 6px;
    transition: all 0.3s ease;
  }

  .cn-newsletter__field:focus-within {
    border-color: var(--cn-accent);
    box-shadow: 0 0 0 4px rgba(var(--cn-accent-rgb), 0.1);
  }

  .cn-newsletter__input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--cn-text);
    padding: 12px 18px;
    font-size: 15px;
    outline: none;
    width: 100%;
  }

  .cn-newsletter__submit {
    background: var(--cn-accent);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0 24px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .cn-newsletter__submit:hover {
    transform: scale(1.02);
    filter: brightness(1.1);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .cn-newsletter {
      flex-direction: column;
      text-align: center;
    }
    .cn-newsletter__form {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .cn-container {
      padding: 0 24px;
    }
  }
{%- endstyle -%}

<section class="custom-newsletter-v2">
  <div class="cn-container">
    <div class="cn-newsletter">
      <div class="cn-newsletter__info">
        <h2 class="cn-newsletter__title">{{ section.settings.newsletter_title }}</h2>
        <p class="cn-newsletter__subtitle">{{ section.settings.newsletter_subtitle }}</p>
      </div>
      <div class="cn-newsletter__form">
        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="cn-newsletter__field">
            <input
              type="email"
              name="contact[email]"
              class="cn-newsletter__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="Newsletter-error--{{ section.id }}"
              {% elsif form.posted_successfully? %}
                aria-describedby="Newsletter-success--{{ section.id }}"
              {% endif %}
              placeholder="Enter your email"
              required
            >
            <button type="submit" class="cn-newsletter__submit" name="commit">
              Subscribe
            </button>
          </div>
          {%- if form.errors -%}
            <small class="form__message" id="Newsletter-error--{{ section.id }}" style="margin-top: 10px; display: block; color: #ff4d4d;">
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <h3
              class="form__message"
              id="Newsletter-success--{{ section.id }}"
              tabindex="-1"
              autofocus
              style="margin-top: 10px; color: #4caf50;"
            >
              Successfully subscribed!
            </h3>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Newsletter V2",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "rgba(0,0,0,0.1)"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Join the Elite"
    },
    {
      "type": "text",
      "id": "newsletter_subtitle",
      "label": "Newsletter Subtitle",
      "default": "Subscribe to receive updates, access to exclusive deals, and more."
    }
  ],
  "presets": [
    {
      "name": "Custom Newsletter V2"
    }
  ]
}
{% endschema %}
