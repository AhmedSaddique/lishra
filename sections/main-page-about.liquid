<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section page-width-content color-{{ section.settings.color_scheme }}">
  {% liquid
    assign page_obj = closest.page | default: page
    assign hero_image = section.settings.hero_image
  %}

  <div
    class="about-page spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="about-page__hero">
      <div class="about-page__hero-text">
        <p class="about-page__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h1 class="about-page__title">
          {{ section.settings.heading | default: page_obj.title | escape }}
        </h1>
        {% if section.settings.subheading != blank %}
          <p class="about-page__subheading">{{ section.settings.subheading | escape }}</p>
        {% endif %}

        {% if section.settings.intro != blank %}
          <div class="about-page__intro rte">
            {{ section.settings.intro }}
          </div>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
          <a class="about-page__cta" href="{{ section.settings.cta_link }}">
            {{ section.settings.cta_label | escape }}
          </a>
        {% endif %}
      </div>

      <div class="about-page__hero-media">
        {% if hero_image %}
          {{
            hero_image
            | image_url: width: 1600
            | image_tag:
              widths: '480, 720, 960, 1200, 1600',
              alt: section.settings.heading | default: page_obj.title,
              class: 'about-page__hero-img',
              loading: 'lazy'
          }}
        {% else %}
          <div class="about-page__hero-placeholder">
            {{ 'image' | placeholder_svg_tag: 'about-page__hero-svg' }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_stats %}
      <div class="about-page__stats">
        <div class="about-page__stat">
          <p class="about-page__stat-number">{{ section.settings.stat_1_number | escape }}</p>
          <p class="about-page__stat-label">{{ section.settings.stat_1_label | escape }}</p>
        </div>
        <div class="about-page__stat">
          <p class="about-page__stat-number">{{ section.settings.stat_2_number | escape }}</p>
          <p class="about-page__stat-label">{{ section.settings.stat_2_label | escape }}</p>
        </div>
        <div class="about-page__stat">
          <p class="about-page__stat-number">{{ section.settings.stat_3_number | escape }}</p>
          <p class="about-page__stat-label">{{ section.settings.stat_3_label | escape }}</p>
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="about-page__features">
        {% for block in section.blocks %}
          <div class="about-page__feature" {{ block.shopify_attributes }}>
            <p class="about-page__feature-title">{{ block.settings.title | escape }}</p>
            <p class="about-page__feature-text">{{ block.settings.text | escape }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if page_obj and page_obj.content != blank %}
      <div class="about-page__content rte">
        {{ page_obj.content }}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .about-page {
    --ap-border: rgb(var(--color-border-rgb) / var(--opacity-20));
    --ap-muted: rgb(var(--color-foreground-rgb) / var(--opacity-70));
    --ap-soft: rgb(var(--color-foreground-rgb) / var(--opacity-5));

    display: flex;
    flex-direction: column;
    gap: clamp(22px, 4vw, 44px);
  }

  .about-page__hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(18px, 3vw, 32px);
    align-items: center;
    padding: clamp(16px, 3vw, 24px);
    border: 1px solid var(--ap-border);
    border-radius: 22px;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 20% 0%, rgb(var(--color-foreground-rgb) / var(--opacity-5)) 0%, transparent 55%),
      radial-gradient(120% 120% at 80% 20%, rgb(var(--color-foreground-rgb) / var(--opacity-5)) 0%, transparent 55%),
      rgb(var(--color-background-rgb) / 1);
  }

  @media screen and (min-width: 990px) {
    .about-page__hero {
      grid-template-columns: 1.1fr 0.9fr;
      padding: 28px;
    }
  }

  .about-page__eyebrow {
    margin: 0 0 10px;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    color: var(--ap-muted);
    font-size: var(--font-size--sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-page__title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    letter-spacing: -0.02em;
    line-height: 1.08;
    font-size: clamp(32px, 4vw, 54px);
  }

  .about-page__subheading {
    margin: 12px 0 0;
    color: var(--ap-muted);
    font-size: clamp(14px, 1.6vw, 18px);
    line-height: 1.6;
  }

  .about-page__intro {
    margin-top: 14px;
    color: var(--ap-muted);
    font-size: var(--font-size--md);
    line-height: 1.7;
  }

  .about-page__cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 12px 16px;
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-background);
    background: var(--color-foreground);
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-30));
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .about-page__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgb(var(--color-shadow-rgb) / var(--opacity-20));
  }

  .about-page__hero-media {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--ap-border);
    background: var(--ap-soft);
    aspect-ratio: 4 / 5;
    max-height: 520px;
  }

  .about-page__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-page__hero-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
  }

  .about-page__hero-svg {
    width: 70%;
    height: 70%;
    opacity: 0.35;
  }

  .about-page__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media screen and (min-width: 750px) {
    .about-page__stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about-page__stat {
    padding: 16px 16px 14px;
    border: 1px solid var(--ap-border);
    border-radius: 18px;
    background: var(--ap-soft);
  }

  .about-page__stat-number {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    letter-spacing: -0.02em;
    font-size: clamp(18px, 2.2vw, 22px);
  }

  .about-page__stat-label {
    margin: 6px 0 0;
    color: var(--ap-muted);
    font-size: var(--font-size--sm);
    line-height: 1.4;
  }

  .about-page__features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media screen and (min-width: 990px) {
    .about-page__features {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about-page__feature {
    padding: 16px;
    border: 1px solid var(--ap-border);
    border-radius: 18px;
    background: rgb(var(--color-background-rgb) / 1);
  }

  .about-page__feature-title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    letter-spacing: -0.01em;
  }

  .about-page__feature-text {
    margin: 8px 0 0;
    color: var(--ap-muted);
    line-height: 1.6;
  }

  .about-page__content {
    padding: clamp(16px, 3vw, 24px);
    border: 1px solid var(--ap-border);
    border-radius: 22px;
    background: rgb(var(--color-background-rgb) / 1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About page",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Girls Cream Cosmetics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty that feels like you"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Modern cosmetics made to elevate your everyday routine with confident shades and skin-loving formulas."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>We believe beauty should be effortless and expressive. Our products are designed for real life: lightweight, buildable, and always comfortable.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop bestsellers"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show stats",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 number",
      "default": "5+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Years creating everyday essentials"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Made to feel comfortable on skin"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 number",
      "default": "24/7"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Glow-ready for every plan"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 88
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Skin-first formulas"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Lightweight textures that layer beautifully and feel comfortable all day."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About page",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Skin-first formulas",
            "text": "Lightweight textures that layer beautifully and feel comfortable all day."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Modern shades",
            "text": "Wearable colors built for daily looks and special moments."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Designed for real life",
            "text": "Easy routines, quick touch-ups, and results that look like you."
          }
        }
      ]
    }
  ]
}
{% endschema %}

